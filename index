    return all.filter(w=>w.date>=fmtKey(cutoff)).sort((a,b)=>b.date.localeCompare(a.date));
  });
  const [editDate,setEditDate]=useState(null);
  const [editVal,setEditVal]=useState("");

  const saveAll = next => { setLog(next); saveWeights([...loadWeights().filter(w=>!next.find(n=>n.date===w.date)), ...next].sort((a,b)=>a.date.localeCompare(b.date))); };

  const commitEdit = date => {
    const n=parseFloat(editVal);
    if(!isNaN(n)&&n>0){
      const next=log.map(w=>w.date===date?{...w,value:n}:w);
      saveAll(next);
    }
    setEditDate(null);
  };

  const deleteEntry = date => {
    const next=log.filter(w=>w.date!==date);
    setLog(next);
    saveWeights(loadWeights().filter(w=>w.date!==date));
  };

  const fmt = dateStr => {
    const d=new Date(dateStr+"T12:00:00");
    return d.toLocaleDateString("en-US",{weekday:"short",month:"short",day:"numeric"});
  };

  return <div style={{height:"100%",background:C.bg,overflowY:"auto",paddingBottom:48}}>
    <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",padding:"calc(env(safe-area-inset-top,44px) + 12px) 16px 20px"}}>
      <button style={{width:44,height:44,borderRadius:12,background:C.hover,border:`1px solid ${C.border}`,color:C.text,display:"flex",alignItems:"center",justifyContent:"center"}} onClick={onBack}><IcBack/></button>
      <span style={{fontSize:16,fontWeight:500,color:C.text}}>Weight History</span>
      <div style={{width:44}}/>
    </div>
    <div style={{padding:"0 16px"}}>
      <p style={{fontSize:12,fontWeight:300,color:C.dim,marginBottom:16}}>Last 30 days — swipe left to delete</p>
      {log.length===0&&<div style={{display:"flex",flexDirection:"column",alignItems:"center",padding:"48px 0",gap:10}}>
        <span style={{fontSize:36}}>⚖️</span>
        <p style={{color:C.sub,fontSize:14,fontWeight:300,textAlign:"center"}}>No weight entries yet.</p>
      </div>}
      {log.map(w=><WeightRow key={w.date} entry={w} isEditing={editDate===w.date} editVal={editVal} setEditVal={setEditVal} onTapEdit={()=>{setEditDate(w.date);setEditVal(String(w.value));}} onCommit={()=>commitEdit(w.date)} onDelete={()=>deleteEntry(w.date)} fmt={fmt}/>)}
    </div>
  </div>;
}

function WeightRow({entry,isEditing,editVal,setEditVal,onTapEdit,onCommit,onDelete,fmt}) {
  const [swipeX,setSwipeX]=useState(0);const[swiping,setSwiping]=useState(false);
  const tx=useRef(0),ty=useRef(0);const THRESHOLD=70;
  const onTS=e=>{tx.current=e.touches[0].clientX;ty.current=e.touches[0].clientY;setSwiping(false);};
  const onTM=e=>{const dx=e.touches[0].clientX-tx.current;const dy=Math.abs(e.touches[0].clientY-ty.current);if(dy>20&&Math.abs(dx)<20)return;if(dx<0){setSwiping(true);setSwipeX(Math.max(dx,-(THRESHOLD+20)));}};
  const onTE=()=>{if(swipeX<=-THRESHOLD)onDelete();else{setSwipeX(0);setSwiping(false);}};
  return <div style={{position:"relative",marginBottom:8,borderRadius:14,overflow:"hidden"}}>
    <div style={{position:"absolute",inset:0,background:C.red,display:"flex",alignItems:"center",justifyContent:"flex-end",paddingRight:18}}>
      <span style={{color:"#fff",fontSize:12,fontWeight:400,marginRight:4}}>Delete</span><IcTrash/>
    </div>
    <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",padding:"14px 16px",background:C.surface,border:`1px solid ${C.border}`,borderRadius:14,transform:`translateX(${swipeX}px)`,transition:swiping?"none":"transform 0.3s ease"}}
      onTouchStart={onTS} onTouchMove={onTM} onTouchEnd={onTE}>
      <span style={{fontSize:13,fontWeight:300,color:C.sub}}>{fmt(entry.date)}</span>
      <div style={{display:"flex",alignItems:"baseline",gap:6}}>
        {isEditing
          ?<input autoFocus type="number" inputMode="decimal" style={{width:70,background:"transparent",border:"none",borderBottom:`2px solid ${C.accent}`,color:C.accent,fontSize:18,fontWeight:200,fontFamily:"'Inter',sans-serif",textAlign:"right",outline:"none",letterSpacing:"-0.5px"}} value={editVal} onChange={e=>setEditVal(e.target.value)} onBlur={onCommit} onKeyDown={e=>e.key==="Enter"&&onCommit()}/>
          :<span style={{fontSize:18,fontWeight:200,color:C.text,letterSpacing:"-0.5px",cursor:"pointer"}} onClick={onTapEdit}>{entry.value}</span>
        }
        <span style={{fontSize:11,fontWeight:300,color:C.dim}}>lbs</span>
        {!isEditing&&<span style={{color:C.dim,cursor:"pointer",display:"inline-flex",alignItems:"center"}} onClick={onTapEdit}><IcEdit/></span>}
      </div>
    </div>
  </div>;
}

function App() {
  const [apiKey,setApiKey]=useState(()=>loadKey());
  const [screen,setScreen]=useState("home");

  const [baseGoal,setBaseGoal]=useState(()=>loadBaseGoal());
  const [selected,setSelected]=useState(null);
  const [camImg,setCamImg]=useState({imageData:null,preview:null});
  const dateKeyRef=useRef(fmtKey(new Date()));
  const [,forceRender]=useState(0);
  const bump=()=>forceRender(n=>n+1);
  const dateKey=dateKeyRef.current;
  const meals=loadMeals(dateKey);
  const burned=meals.filter(m=>m.type==="workout").reduce((s,m)=>s+m.totalCalories,0);
  const effectiveGoal=baseGoal+burned;
  const changeDate=d=>{const k=fmtKey(d);if(k===dateKeyRef.current)return;dateKeyRef.current=k;bump();};
  const addMeal=async m=>{
    recordFoodItems(m.ingredients);
    const k=dateKeyRef.current;
    let storable=m;
    if(m.imageBase64){
      const thumb=await makeThumbnail(m.imageBase64, m.imageMime||"image/jpeg", 120, 0.7);
      storable={...m, imageBase64:thumb||null};
    }
    saveMeals(k,[...loadMeals(k),storable]);
    setScreen("home");
    bump();
  };
  const addWorkout=w=>{const k=dateKeyRef.current;saveMeals(k,[...loadMeals(k),w]);bump();};
  const updateMeal=m=>{recordFoodItems(m.ingredients);const k=dateKeyRef.current;saveMeals(k,loadMeals(k).map(x=>x.id===m.id?m:x));setSelected(m);bump();};
  const deleteMeal=id=>{const k=dateKeyRef.current;saveMeals(k,loadMeals(k).filter(x=>x.id!==id));setScreen("home");bump();};
  const saveApiKey=k=>{saveKey(k);setApiKey(k);};
  const selectMeal=m=>{
    if(m._quickEdit){const k=dateKeyRef.current;saveMeals(k,loadMeals(k).map(x=>x.id===m.id?{...x,totalCalories:m._newCal}:x));bump();return;}
    if(m._delete){const k=dateKeyRef.current;saveMeals(k,loadMeals(k).filter(x=>x.id!==m.id));bump();return;}
    setSelected(m);setScreen("detail");
  };

  if (!apiKey) return <ApiKeyScreen onSave={saveApiKey}/>;

  return <div style={{height:"100%"}}>
    {screen==="home"&&<HomeScreen
      onOpenCamera={(imageData,preview)=>{setCamImg({imageData,preview});setScreen("camera");}}
      onOpenVoice={()=>setScreen("voice")}
      onAddWorkout={addWorkout} onSelectMeal={selectMeal}
      onOpenSettings={()=>setScreen("settings")}
      onOpenWeightHistory={()=>setScreen("weightHistory")}
      meals={meals} goal={effectiveGoal} baseGoal={baseGoal}
      setBaseGoal={n=>{setBaseGoal(n);saveBaseGoal(n);}}
      date={new Date(dateKey+"T12:00:00")} setDate={changeDate}
    />}
    {screen==="camera"&&<PhotoScreen apiKey={apiKey} imageData={camImg.imageData} imagePreview={camImg.preview} onBack={()=>setScreen("home")} onAdd={addMeal}/>}
    {screen==="voice"&&<VoiceScreen apiKey={apiKey} onBack={()=>setScreen("home")} onAdd={addMeal}/>}
    {screen==="detail"&&selected&&<DetailScreen meal={selected} onBack={()=>setScreen("home")} onUpdate={updateMeal} onDelete={deleteMeal} apiKey={apiKey}/>}
    {screen==="settings"&&<SettingsScreen apiKey={apiKey} onSave={saveApiKey} onBack={()=>setScreen("home")}/>}
    {screen==="weightHistory"&&<WeightHistoryScreen onBack={()=>setScreen("home")}/>}
  </div>;
}

ReactDOM.createRoot(document.getElementById("root")).render(<App/>);
</script>
</body>
</html>
