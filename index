// Each ingredient stores: name, calories (current total), proteinG (current total),
// baseCalories (per-serving), baseProteinG (per-serving), servings (float)
function SwipeIngRow({ing,idx,editIdx,editField,servVal,calVal,setServVal,setCalVal,setEditIdx,commitServ,commitCal,onDelete}) {
  const [swipeX,setSwipeX]=useState(0);const[swiping,setSwiping]=useState(false);
  const tx=useRef(0),ty=useRef(0);const THRESHOLD=70;
  const onTS=e=>{tx.current=e.touches[0].clientX;ty.current=e.touches[0].clientY;setSwiping(false);setSwipeX(0);};
  const onTM=e=>{const dx=e.touches[0].clientX-tx.current;const dy=Math.abs(e.touches[0].clientY-ty.current);if(dy>20&&Math.abs(dx)<20)return;if(dx<-8){setSwiping(true);setSwipeX(Math.max(dx,-(THRESHOLD+20)));}};
  const onTE=e=>{
    const dx=Math.abs(e.changedTouches[0].clientX-tx.current);
    if(dx<8){setSwipeX(0);setSwiping(false);return;} // it was a tap, not a swipe
    if(swipeX<=-THRESHOLD)onDelete(idx);else{setSwipeX(0);setSwiping(false);}
  };;
  const servings = ing.servings ?? 1;
  const editingServ = editIdx===idx && editField==="serv";
  const editingCal  = editIdx===idx && editField==="cal";
  return <div style={{position:"relative",overflow:"hidden",borderTop:`1px solid ${C.border}`}}>
    <div style={{position:"absolute",inset:0,background:C.red,display:"flex",alignItems:"center",justifyContent:"flex-end",paddingRight:16}}>
      <span style={{color:"#fff",fontSize:12,fontWeight:400,marginRight:4}}>Delete</span><IcTrash/>
    </div>
    <div style={{padding:"10px 16px",background:C.surface,transform:`translateX(${swipeX}px)`,transition:swiping?"none":"transform 0.3s ease"}}
      onTouchStart={onTS} onTouchMove={onTM} onTouchEnd={onTE}>
      {/* Name — small, light */}
      <p style={{fontSize:11,fontWeight:300,color:C.sub,marginBottom:6,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{ing.name}</p>
      <div style={{display:"flex",alignItems:"center",justifyContent:"space-between"}}>
        {/* Servings — tappable */}
        <div style={{display:"flex",alignItems:"baseline",gap:4,cursor:"pointer"}}
          onClick={e=>{e.stopPropagation();if(!editingServ){setEditIdx(idx,"serv");setServVal(String(servings));}}}>
          <span style={{fontSize:10,fontWeight:300,color:C.dim,marginRight:2}}>SRV</span>
          {editingServ
            ?<input autoFocus type="number" inputMode="decimal"
                style={{width:60,background:"transparent",border:"none",borderBottom:`2px solid ${C.accent}`,color:C.accent,fontSize:22,fontWeight:200,textAlign:"left",outline:"none",fontFamily:"'Inter',sans-serif",letterSpacing:"-0.5px",padding:0}}
                value={servVal} onChange={e=>setServVal(e.target.value)}
                onBlur={()=>commitServ(idx)} onKeyDown={e=>e.key==="Enter"&&commitServ(idx)}/>
            :<span style={{fontSize:22,fontWeight:200,color:C.text,letterSpacing:"-0.5px"}}>{servings}</span>
          }
          {!editingServ&&<span style={{color:C.dim,display:"inline-flex",alignItems:"center",marginLeft:2}}><IcEdit size={11}/></span>}
        </div>
        {/* Calories — tappable */}
        <div style={{display:"flex",alignItems:"baseline",gap:4,cursor:"pointer"}}
          onClick={e=>{e.stopPropagation();if(!editingCal){setEditIdx(idx,"cal");setCalVal(String(ing.calories));}}}>
          <span style={{fontSize:10,fontWeight:300,color:C.dim,marginRight:2}}>CAL</span>
          {editingCal
            ?<input autoFocus type="number" inputMode="numeric"
                style={{width:70,background:"transparent",border:"none",borderBottom:`2px solid ${C.accent}`,color:C.accent,fontSize:22,fontWeight:200,textAlign:"right",outline:"none",fontFamily:"'Inter',sans-serif",letterSpacing:"-0.5px",padding:0}}
                value={calVal} onChange={e=>setCalVal(e.target.value)}
                onBlur={()=>commitCal(idx)} onKeyDown={e=>e.key==="Enter"&&commitCal(idx)}/>
            :<span style={{fontSize:22,fontWeight:200,color:C.accent,letterSpacing:"-0.5px"}}>{ing.calories}</span>
          }
          {!editingCal&&<span style={{color:C.dim,display:"inline-flex",alignItems:"center",marginLeft:2}}><IcEdit size={11}/></span>}
          {(ing.proteinG||0)>0&&<span style={{fontSize:10,fontWeight:300,color:"rgba(96,200,245,0.6)",marginLeft:6}}>{Math.round(ing.proteinG)}g pro</span>}
        </div>
      </div>
    </div>
  </div>;
}

function DetailScreen({meal,onBack,onUpdate,onDelete,apiKey}) {
  // Parse servings hints from ingredient names like "1.5 servings of balsamic dressing"
  const parseServings = ing => {
    if (ing.servings != null && ing.servings !== 1) return ing; // already set
    const m = ing.name.match(/^([\d.\/]+)\s*(?:servings?|srv|x)\s+(?:of\s+)?/i);
    if (m) {
      const n = parseFloat(m[1]);
      if (!isNaN(n) && n > 0 && n !== 1) {
        const baseCal = ing.baseCalories ?? Math.round(ing.calories / n);
        const baseProt = ing.baseProteinG ?? Math.round(((ing.proteinG||0) / n)*10)/10;
        return {...ing, servings:n, baseCalories:baseCal, baseProteinG:baseProt};
      }
    }
    return ing;
  };
  const normalise = ings => ings.map(ing=>parseServings({
    ...ing,
    baseCalories: ing.baseCalories ?? ing.calories,
    baseProteinG: ing.baseProteinG ?? (ing.proteinG||0),
    servings: ing.servings ?? 1,
  }));
  const [ings,setIngs]=useState(()=>normalise(meal.ingredients||[]));
  const [editTotal,setEditTotal]=useState(false);
  const [totalVal,setTotalVal]=useState(String(meal.totalCalories));
  const [editIdx,setEditIdx]=useState(null);
  const [editField,setEditField]=useState(null); // "serv" | "cal"
  const [servVal,setServVal]=useState("");
  const [calVal,setCalVal]=useState("");
  const [addingVoice,setAddingVoice]=useState(false);
  const [addTranscript,setAddTranscript]=useState("");
  const [addError,setAddError]=useState("");
  const [addLoading,setAddLoading]=useState(false);
  const isWorkout=meal.type==="workout";

  const setEditIdx2 = (idx, field) => { setEditIdx(idx); setEditField(field); };

  const onUpdate2 = useCallback(t=>setAddTranscript(t),[]);
  const speech = useWebSpeech(onUpdate2);
  useEffect(()=>()=>speech.stop(),[]);

  const save = (newIngs) => {
    const newTot = Math.round(newIngs.reduce((s,x)=>s+x.calories,0));
    const newProt = newIngs.reduce((s,x)=>s+(x.proteinG||0),0);
    setTotalVal(String(newTot));
    onUpdate({...meal, totalCalories:newTot, totalProteinG:newProt, ingredients:newIngs});
  };

  const commitTotal=()=>{const n=parseInt(totalVal);if(!isNaN(n)&&n>=0)onUpdate({...meal,totalCalories:n,ingredients:ings});else setTotalVal(String(meal.totalCalories));setEditTotal(false);};

  const commitServ = idx => {
    const n = parseFloat(servVal);
    if (!isNaN(n) && n > 0) {
      const next = ings.map((x,i) => {
        if (i !== idx) return x;
        const newCal = Math.round(x.baseCalories * n);
        const newProt = Math.round((x.baseProteinG||0) * n * 10) / 10;
        return {...x, servings:n, calories:newCal, proteinG:newProt};
      });
      setIngs(next);
      save(next);
    }
    setEditIdx(null); setEditField(null);
  };

  const commitCal = idx => {
    const n = parseInt(calVal);
    if (!isNaN(n) && n >= 0) {
      const next = ings.map((x,i) => {
        if (i !== idx) return x;
        // Update base calories too so future serving changes stay accurate
        const newBase = x.servings > 0 ? Math.round(n / x.servings) : n;
        return {...x, calories:n, baseCalories:newBase};
      });
      setIngs(next);
      save(next);
    }
    setEditIdx(null); setEditField(null);
  };

  const mergeItems = async () => {
    if (!addTranscript.trim()) return;
    speech.stop();
    setAddLoading(true);
    setAddError("");
    try {
      const r = await analyze(apiKey, null, addTranscript);
      const raw = r.ingredients||[{name:r.mealTitle,calories:r.totalCalories,proteinG:r.totalProteinG||0}];
      const newIngs = [...ings, ...normalise(raw)];
      setIngs(newIngs);
      save(newIngs);
      setAddTranscript("");
      setAddingVoice(false);
    } catch(e) { setAddError(e.message||"Error — try again"); }
    setAddLoading(false);
  };

  return <div style={{height:"100%",background:C.bg,overflowY:"auto",paddingBottom:48}}>
    <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",padding:"calc(env(safe-area-inset-top,44px) + 12px) 16px 12px"}}>
      <button style={{width:44,height:44,borderRadius:12,background:C.hover,border:`1px solid ${C.border}`,color:C.text,display:"flex",alignItems:"center",justifyContent:"center"}} onClick={onBack}><IcBack/></button>
      <span style={{fontSize:16,fontWeight:500,color:C.text}}>{isWorkout?"Workout":"Meal Details"}</span>
      <button style={{width:44,height:44,borderRadius:12,background:C.rDim,border:`1px solid ${C.rMid}`,color:C.red,display:"flex",alignItems:"center",justifyContent:"center"}} onClick={()=>onDelete(meal.id)}><IcTrash/></button>
    </div>
    {!isWorkout&&(meal.imageBase64?<img src={`data:${meal.imageMime||"image/jpeg"};base64,${meal.imageBase64}`} style={{width:"100%",height:250,objectFit:"cover"}} alt=""/>:<div style={{width:"100%",height:180,background:C.surface,display:"flex",alignItems:"center",justifyContent:"center"}}><span style={{fontSize:56}}>{meal.emoji||"🍽️"}</span></div>)}
    {isWorkout&&<div style={{width:"100%",height:140,background:C.oDim,display:"flex",alignItems:"center",justifyContent:"center"}}><span style={{fontSize:64}}>🔥</span></div>}
    <div style={{padding:"20px 20px 40px"}}>
      <h2 style={{fontSize:22,fontWeight:400,color:isWorkout?C.orange:C.text,marginBottom:6,letterSpacing:"-0.3px"}}>{meal.mealTitle}</h2>
      <p style={{fontSize:13,fontWeight:300,color:C.sub,lineHeight:1.6,marginBottom:5}}>{meal.summary}</p>
      <p style={{fontSize:11,color:C.dim,marginBottom:20}}>{meal.time}</p>
      <div style={{display:"flex",gap:10,marginBottom:18}}>
        <div style={{flex:1,display:"flex",alignItems:"center",justifyContent:"space-between",padding:"16px 18px",background:isWorkout?C.oDim:C.aDim,border:`1px solid ${isWorkout?C.oMid:C.aMid}`,borderRadius:16,cursor:"pointer"}} onClick={()=>{setTotalVal(String(meal.totalCalories));setEditTotal(true);}}>
          <span style={{fontSize:13,fontWeight:400,color:C.text}}>{isWorkout?"Calories Burned":"Calories"}</span>
          {editTotal
            ?<input autoFocus type="number" inputMode="numeric" style={{width:80,background:"transparent",border:"none",borderBottom:`2px solid ${isWorkout?C.orange:C.accent}`,color:isWorkout?C.orange:C.accent,fontSize:26,fontWeight:200,fontFamily:"'Inter',sans-serif",outline:"none",textAlign:"right"}} value={totalVal} onChange={e=>setTotalVal(e.target.value)} onBlur={commitTotal} onKeyDown={e=>e.key==="Enter"&&commitTotal()} onClick={e=>e.stopPropagation()}/>
            :<div style={{display:"flex",alignItems:"center",gap:5,color:isWorkout?C.orange:C.accent}}><span style={{fontSize:26,fontWeight:200,letterSpacing:"-1.5px"}}>{meal.totalCalories}</span><span style={{fontSize:11,opacity:0.7}}>kcal</span><IcEdit size={13}/></div>
          }
        </div>
        {!isWorkout&&(meal.totalProteinG||0)>0&&<div style={{padding:"16px 14px",background:"rgba(96,200,245,0.1)",border:"1px solid rgba(96,200,245,0.3)",borderRadius:16,display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",minWidth:72}}>
          <span style={{fontSize:20,fontWeight:200,color:"#60C8F5",letterSpacing:"-0.5px"}}>{Math.round(meal.totalProteinG||0)}g</span>
          <span style={{fontSize:9,color:C.dim,textTransform:"uppercase",letterSpacing:"0.5px",marginTop:1}}>protein</span>
        </div>}
      </div>

      {!isWorkout&&<div style={{background:C.surface,borderRadius:16,border:`1px solid ${C.border}`,overflow:"hidden",marginBottom:12}}>
        <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",padding:"12px 16px 8px"}}>
          <p style={{fontSize:11,fontWeight:400,color:C.sub,textTransform:"uppercase",letterSpacing:"1.2px"}}>Breakdown</p>
          {!addingVoice&&<button style={{display:"flex",alignItems:"center",gap:5,background:C.aDim,border:`1px solid ${C.aMid}`,borderRadius:8,color:C.accent,fontSize:11,fontWeight:500,padding:"5px 10px"}} onClick={()=>{setAddingVoice(true);setAddTranscript("");setAddError("");setTimeout(()=>speech.start(),100);}}>
            <IcMic size={12}/> Add item
          </button>}
        </div>
        {ings.map((ing,idx)=><SwipeIngRow key={idx} ing={ing} idx={idx} editIdx={editIdx} editField={editField} servVal={servVal} calVal={calVal} setServVal={setServVal} setCalVal={setCalVal} setEditIdx={setEditIdx2} commitServ={commitServ} commitCal={commitCal} onDelete={i=>{const next=ings.filter((_,j)=>j!==i);setIngs(next);save(next);}}/>)}

        {addingVoice&&<div style={{padding:"12px 14px",borderTop:`1px solid ${C.border}`}}>
          <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:8}}>
            <div onClick={speech.listening?speech.stop:speech.start}
