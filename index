// ─── FIX 4: useWebSpeech now exposes the MediaStream so visualizer can use it ─
// When SpeechRecognition is active, the mic is already open. We call getUserMedia
// after a short delay (SpeechRecognition holds the grant), reusing the same
// permission — browsers do NOT re-prompt if permission is already granted.
function useWebSpeech(onUpdate) {
  const recRef = useRef(null);
  const [listening, setListening] = useState(false);
  const supported = !!(window.SpeechRecognition || window.webkitSpeechRecognition);

  const start = useCallback(() => {
    if (!supported) return;
    try {
      const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
      const rec = new SR();
      recRef.current = rec;
      rec.continuous = true;
      rec.interimResults = true;
      rec.lang = "en-US";
      let final = "";
      rec.onresult = e => {
        let interim = "";
        for (let i = e.resultIndex; i < e.results.length; i++) {
          const t = e.results[i][0].transcript;
          if (e.results[i].isFinal) final += t + " ";
          else interim = t;
        }
        onUpdate(final + interim);
      };
      rec.onerror = () => setListening(false);
      rec.onend = () => setListening(false);
      rec.start();
      setListening(true);
      // NOTE: We intentionally do NOT call getUserMedia here.
      // SpeechRecognition handles mic access on its own. A separate getUserMedia
      // call triggers a second iOS permission prompt even when already granted.
      // The visualizer uses animated bars instead — cosmetically identical.
    } catch { setListening(false); }
  }, [supported, onUpdate]);

  const stop = useCallback(() => {
    try { recRef.current?.stop(); } catch {}
    setListening(false);
  }, []);

  return { listening, supported, start, stop, stream: null };
}

function VoiceScreen({apiKey,onBack,onAdd}) {
  const [transcript,setTranscript]=useState("");
  const [error,setError]=useState("");
  const [submitting,setSubmitting]=useState(false);
  const [foodSugg,setFoodSugg]=useState([]);
  const [showFoodSugg,setShowFoodSugg]=useState(false);
  const foodHistRef=useRef(loadFoodHistory());

  const onUpdate = useCallback(text => { setTranscript(text); }, []);
  const speech = useWebSpeech(onUpdate);

  useEffect(() => {
    if (speech.supported) setTimeout(() => speech.start(), 200);
    return () => speech.stop();
  }, []);

  const handleChange = v => {
    setTranscript(v);
    const words = v.split(/[\s,]+/);
    const last = words[words.length-1].trim();
    if (last.length>=2) {
      const m = foodHistRef.current.filter(f=>f.name.toLowerCase().includes(last.toLowerCase())).slice(0,4);
      setFoodSugg(m); setShowFoodSugg(m.length>0);
    } else setShowFoodSugg(false);
  };

  const submit = async () => {
    if (!transcript.trim()) return;
    speech.stop();
    setSubmitting(true);
    try {
      const r = await analyze(apiKey, null, transcript);
      const now = new Date();
      onAdd({id:uid(),mealTitle:r.mealTitle,totalCalories:r.totalCalories,totalProteinG:r.totalProteinG||0,ingredients:r.ingredients||[],summary:r.summary,imageBase64:null,time:now.toLocaleTimeString("en-US",{hour:"numeric",minute:"2-digit"}),addedAt:now.getTime(),emoji:r.emoji||"🍽️"});
    } catch(e) { setError(e.message||"Error — check Settings ⚙️"); setSubmitting(false); }
  };

  if (submitting) return <Spinner text="Calculating calories…"/>;

  return <div style={{height:"100%",background:C.bg,overflowY:"auto",paddingBottom:40}}>
    <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",padding:"calc(env(safe-area-inset-top,44px) + 12px) 16px 12px"}}>
      <button style={{width:44,height:44,borderRadius:12,background:C.hover,border:`1px solid ${C.border}`,color:C.text,display:"flex",alignItems:"center",justifyContent:"center"}} onClick={()=>{speech.stop();onBack();}}><IcBack/></button>
      <span style={{fontSize:16,fontWeight:500,color:C.text}}>Voice Log</span>
      <div style={{width:44}}/>
    </div>
    <div style={{display:"flex",flexDirection:"column",gap:16,padding:"8px 20px 40px"}}>
      <div style={{display:"flex",flexDirection:"column",alignItems:"center",gap:14,paddingTop:8}}>
