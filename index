// ─── FIX 1: Remove temperature param — gpt-5.5 only supports default (1) ─────
// ─── FIX 2: Use max_completion_tokens (correct param for newer models) ────────
async function analyze(apiKey, imageData, description) {
  if (!apiKey) throw new Error("No API key — tap ⚙️ Settings to add your OpenAI key");

  const sysPrompt = `You are an expert nutritionist and food label reader with access to USDA databases, restaurant nutrition facts, and packaged food data.

BARCODE & PACKAGING:
- If you see a barcode, UPC, or food package: read ALL visible text including brand name, product name, flavor, size, and any nutrition panel. Use the EXACT published nutrition facts for that specific product.
- Examples: Fairlife 2% milk 11.5oz = 170cal/13g protein. Premier Protein shake = 160cal/30g protein. Kind bar peanut butter = 200cal/7g protein.

RESTAURANT & BRAND FOOD:
- Use real published nutrition data. Examples: Big Mac = 550cal/25g protein. Chipotle chicken burrito bowl (standard) ~800cal/50g protein. Starbucks grande latte whole milk = 220cal/12g protein.

HOMEMADE / PLATED FOOD:
- Estimate the ACTUAL portion size visible in the photo. Look for visual cues: plate size, utensils, food density.
- Never default to a "standard serving" — judge what's actually in the image.

QUANTITIES:
- If user says "two", "3x", "a dozen" etc, multiply all values by that number.

ACCURACY RULES:
- Never return 0 calories for any real food item.
- totalCalories MUST equal the sum of all ingredient calories.
- Estimate totalProteinG and proteinG for every ingredient.
- For emoji: pick ONE emoji that best represents the main food item.
- Return ONLY raw JSON. No markdown fences, no explanation text, nothing else.`;

  const userPrompt = imageData
    ? `Analyze this image carefully.${description ? ` User added: "${description}".` : ""} If you see a barcode or package, identify the exact product and use its real nutrition facts. Return this exact JSON: {"mealTitle":"...","totalCalories":0,"totalProteinG":0,"emoji":"🍔","ingredients":[{"name":"...","calories":0,"proteinG":0}],"summary":"..."}`
    : `The user described their meal: "${description}". Use real brand/USDA data and multiply by any stated quantity. Return this exact JSON: {"mealTitle":"...","totalCalories":0,"totalProteinG":0,"emoji":"🍔","ingredients":[{"name":"...","calories":0,"proteinG":0}],"summary":"..."}`;

  const contentArr = [];
  if (imageData) {
    contentArr.push({
      type: "image_url",
      image_url: { url: `data:${imageData.mimeType};base64,${imageData.base64}`, detail: "high" }
    });
  }
  contentArr.push({ type: "text", text: userPrompt });

  const res = await fetch("https://api.openai.com/v1/chat/completions", {
    method: "POST",
    headers: { "Content-Type": "application/json", "Authorization": `Bearer ${apiKey}` },
    body: JSON.stringify({
      model: "gpt-5.5",
      messages: [
        { role: "system", content: sysPrompt },
        { role: "user", content: contentArr }
      ],
      max_completion_tokens: 800
      // temperature intentionally omitted — gpt-5.5 only supports the default value of 1
    })
  });

  if (!res.ok) {
    let msg = `API error ${res.status}`;
    try { const e = await res.json(); msg = e.error?.message || msg; } catch {}
    if (res.status === 401) throw new Error("Invalid API key — tap ⚙️ to update it");
    if (res.status === 400) throw new Error(`Bad request: ${msg}`);
    if (res.status === 429) throw new Error("Rate limit — wait a moment and try again");
    throw new Error(msg);
  }

  const data = await res.json();
  const rawText = data.choices?.[0]?.message?.content || "";
  const cleaned = rawText.trim().replace(/```json\s*/gi,"").replace(/```/g,"").trim();
  try { return JSON.parse(cleaned); }
  catch {
    const match = cleaned.match(/\{[\s\S]*\}/);
    if (match) return JSON.parse(match[0]);
    throw new Error("Unexpected response — please try again");
  }
}

function recordFoodItems(ingredients) {
  if (!ingredients?.length) return;
  const existing = loadFoodHistory();
  const map = {};
  existing.forEach(f => { map[f.name.toLowerCase()] = f; });
  ingredients.forEach(f => { map[f.name.toLowerCase()] = {name:f.name,calories:f.calories,proteinG:f.proteinG||0}; });
  saveFoodHistory(Object.values(map).slice(0,100));
}

