// Downscale a full base64 image to a tiny thumbnail for localStorage.
// Keeps stored size ~4-8KB vs 500KB+ for full photos — avoids QuotaExceededError.
function makeThumbnail(base64, mimeType, size=120, quality=0.7) {
  return new Promise(resolve => {
    try {
      const img = new Image();
      img.onload = () => {
        const s = Math.min(size/img.width, size/img.height, 1);
        const w = Math.round(img.width*s), h = Math.round(img.height*s);
        const c = document.createElement("canvas"); c.width=w; c.height=h;
        c.getContext("2d").drawImage(img,0,0,w,h);
        resolve(c.toDataURL("image/jpeg", quality).split(",")[1]);
      };
      img.onerror = () => resolve(null);
      img.src = `data:${mimeType};base64,${base64}`;
    } catch { resolve(null); }
  });
}
