// ─── VoiceVisualizer ─────────────────────────────────────────────────────────
// Accepts mediaStream prop from parent. If no stream given, renders animated
// placeholder bars — zero extra permission prompts.
function VoiceVisualizer({active, mediaStream}) {
  const canvasRef = useRef(null);
  const rafRef = useRef(null);
  const acRef = useRef(null);
  const BARS = 24;

  useEffect(() => {
    const canvas = canvasRef.current; if (!canvas) return;
    const ctx = canvas.getContext("2d");

    const flat = () => {
      ctx.clearRect(0,0,canvas.width,canvas.height);
      const bw = canvas.width/BARS;
      ctx.fillStyle = "rgba(74,230,138,0.18)";
      for(let i=0;i<BARS;i++){
        const h=4;
        ctx.beginPath();
        ctx.roundRect(i*bw+1,(canvas.height-h)/2,bw-2,h,2);
        ctx.fill();
      }
    };

    if (!active) {
      cancelAnimationFrame(rafRef.current);
      try{acRef.current?.close();acRef.current=null;}catch{}
      flat();
      return;
    }

    // No real stream — animate fake bars, no mic permission needed
    if (!mediaStream) {
      let t = 0;
      const animate = () => {
        rafRef.current = requestAnimationFrame(animate);
        ctx.clearRect(0,0,canvas.width,canvas.height);
        const bw=canvas.width/BARS, maxH=canvas.height*0.88;
        for(let i=0;i<BARS;i++){
          const v=Math.abs(Math.sin(t*2.1+i*0.4))*0.55+0.12;
          const h=Math.max(4,v*maxH);
          ctx.fillStyle=`rgba(74,230,138,${0.22+v*0.55})`;
          ctx.beginPath();
          ctx.roundRect(i*bw+1,(canvas.height-h)/2,bw-2,h,3);
          ctx.fill();
        }
        t+=0.05;
      };
      animate();
      return () => cancelAnimationFrame(rafRef.current);
    }

    // Real stream — attach analyser for genuine waveform
    try {
      const ac = new(window.AudioContext||window.webkitAudioContext)();
      acRef.current = ac;
      const src = ac.createMediaStreamSource(mediaStream);
      const an = ac.createAnalyser(); an.fftSize=64; src.connect(an);
      const buf = new Uint8Array(an.frequencyBinCount);
      const draw = () => {
        rafRef.current = requestAnimationFrame(draw);
        an.getByteFrequencyData(buf);
        ctx.clearRect(0,0,canvas.width,canvas.height);
        const bw=canvas.width/BARS,maxH=canvas.height*0.88;
        for(let i=0;i<BARS;i++){
          const v=buf[Math.floor(i*buf.length/BARS)]/255;
          const h=Math.max(4,v*maxH);
          ctx.fillStyle=`rgba(74,230,138,${0.3+v*0.7})`;
          ctx.beginPath();
          ctx.roundRect(i*bw+1,(canvas.height-h)/2,bw-2,h,3);
          ctx.fill();
        }
      };
      draw();
    } catch { flat(); }

    return () => {
      cancelAnimationFrame(rafRef.current);
      try{acRef.current?.close();acRef.current=null;}catch{}
    };
  }, [active, mediaStream]);

  return <div style={{width:"100%",height:52,display:"flex",alignItems:"center"}}>
    <canvas ref={canvasRef} width={340} height={52} style={{width:"100%",height:"100%",opacity:active?1:0.3,transition:"opacity 0.3s"}}/>
  </div>;
}

function WeightSparkline({data}) {
  if (data.length<2) return null;
  const W=120,H=36,P=4,vals=data.map(d=>d.value);
  const mn=Math.min(...vals),mx=Math.max(...vals),lo=mn-0.5,hi=mx+0.5,range=hi-lo||1;
  const tx=i=>P+(i/(data.length-1))*(W-P*2),ty=v=>P+(1-(v-lo)/range)*(H-P*2);
  const pts=data.map((d,i)=>`${tx(i)},${ty(d.value)}`).join(" ");
  const area=`M${tx(0)},${ty(data[0].value)} `+data.slice(1).map((d,i)=>`L${tx(i+1)},${ty(d.value)}`).join(" ")+` L${tx(data.length-1)},${H} L${tx(0)},${H} Z`;
  const last=data[data.length-1].value,prev=data[data.length-2].value,color=last<=prev?C.accent:C.red;
  return <svg width={W} height={H} style={{overflow:"visible"}}>
    <defs><linearGradient id="sg" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stopColor={color} stopOpacity="0.3"/><stop offset="100%" stopColor={color} stopOpacity="0"/></linearGradient></defs>
    <path d={area} fill="url(#sg)"/>
    <polyline points={pts} fill="none" stroke={color} strokeWidth="1.8" strokeLinecap="round" strokeLinejoin="round"/>
    <circle cx={tx(data.length-1)} cy={ty(last)} r="3" fill={color}/>
  </svg>;
}

function MealCard({meal,onTap,onQuickEdit,onDelete}) {
  const [swipeX,setSwipeX]=useState(0);
  const [swiping,setSwiping]=useState(false);
  const tx=useRef(0),ty=useRef(0);
  const isWorkout=meal.type==="workout";
  const THRESHOLD=80;
  // Build a compact serving summary for the card, e.g. "Bread 1 srv · Bacon 2 srv"
  const srvSummary = !isWorkout && meal.ingredients?.length
    ? meal.ingredients.map(i=>`${i.name}${i.servings && i.servings!==1 ? ` ×${i.servings}` : ""}`).slice(0,3).join(" · ") + (meal.ingredients.length>3?" …":"")
    : null;
  const onTS=e=>{tx.current=e.touches[0].clientX;ty.current=e.touches[0].clientY;setSwiping(false);};
  const onTM=e=>{const dx=e.touches[0].clientX-tx.current;const dy=Math.abs(e.touches[0].clientY-ty.current);if(dy>20&&Math.abs(dx)<20)return;if(dx<0){setSwiping(true);setSwipeX(Math.max(dx,-(THRESHOLD+30)));}};
  const onTE=()=>{if(swipeX<=-THRESHOLD){onDelete(meal.id);}else{setSwipeX(0);setSwiping(false);}};
  return <div style={{position:"relative",marginBottom:10,borderRadius:16,overflow:"hidden"}}>
    <div style={{position:"absolute",inset:0,background:C.red,borderRadius:16,display:"flex",alignItems:"center",justifyContent:"flex-end",paddingRight:20}}>
      <span style={{color:"#fff",fontSize:13,fontWeight:400,marginRight:6}}>Delete</span><IcTrash/>
    </div>
    <div style={{display:"flex",alignItems:"center",gap:12,background:C.card,border:`1px solid ${isWorkout?C.oMid:C.border}`,borderRadius:16,padding:"12px 14px",cursor:"pointer",transform:`translateX(${swipeX}px)`,transition:swiping?"none":"transform 0.3s ease"}}
      onClick={()=>{if(swipeX===0)onTap(meal);}}
      onTouchStart={onTS} onTouchMove={onTM} onTouchEnd={onTE}>
      {meal.imageBase64
        ?<img src={`data:${meal.imageMime||"image/jpeg"};base64,${meal.imageBase64}`} style={{width:48,height:48,borderRadius:10,objectFit:"cover",flexShrink:0}} alt=""/>
        :<div style={{width:48,height:48,borderRadius:10,background:isWorkout?C.oDim:C.hover,display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0}}><span style={{fontSize:20}}>{isWorkout?"🔥":meal.emoji||"🍽️"}</span></div>
      }
      <div style={{flex:1,minWidth:0}}>
        <p style={{fontSize:13,fontWeight:400,color:isWorkout?C.orange:C.text,marginBottom:1,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{meal.mealTitle}</p>
        {srvSummary
          ? <p style={{fontSize:11,fontWeight:300,color:C.sub,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",marginBottom:1}}>{srvSummary}</p>
          : <p style={{fontSize:11,fontWeight:300,color:C.sub,lineHeight:1.4,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{meal.summary}</p>
        }
        <p style={{fontSize:10,fontWeight:300,color:C.dim,marginTop:2}}>{meal.time}</p>
      </div>
      <div style={{display:"flex",flexDirection:"column",alignItems:"flex-end",gap:2,flexShrink:0,paddingLeft:8}}>
        <div style={{display:"flex",alignItems:"baseline",gap:3,padding:"6px 10px",background:isWorkout?C.oDim:C.aDim,borderRadius:10}}>
          <span style={{fontSize:18,fontWeight:200,color:isWorkout?C.orange:C.accent,letterSpacing:"-0.5px"}}>{isWorkout?"-":""}{meal.totalCalories}</span>
          <span style={{fontSize:9,fontWeight:300,color:isWorkout?C.oMid:C.aMid,textTransform:"uppercase"}}>cal</span>
        </div>
        {!isWorkout&&(meal.totalProteinG||0)>0&&<span style={{fontSize:10,fontWeight:300,color:"rgba(96,200,245,0.7)"}}>{Math.round(meal.totalProteinG||0)}g pro</span>}
      </div>
    </div>
  </div>;
}

function WorkoutModal({onAdd,onClose}) {
  const [cal,setCal]=useState("");
  const [label,setLabel]=useState(()=>ls.get("jct:lastlabel")||"");
  const [suggestions,setSuggestions]=useState([]);
  const [showSugg,setShowSugg]=useState(false);
  const [allLabels]=useState(()=>loadWorkoutLabels());
  const calRef=useRef();
  useEffect(()=>{setTimeout(()=>calRef.current?.focus(),100);},[]);
  const handleLabelChange=v=>{setLabel(v);if(v.trim()){const m=allLabels.filter(l=>l.toLowerCase().includes(v.toLowerCase())&&l.toLowerCase()!==v.toLowerCase());setSuggestions(m);setShowSugg(m.length>0);}else setShowSugg(false);};
  const submit=()=>{
    const n=parseInt(cal);if(isNaN(n)||n<=0)return;
    const fl=label.trim()||"Workout";ls.set("jct:lastlabel",fl);
    if(fl!=="Workout"){const u=[...new Set([fl,...allLabels])].slice(0,20);saveWorkoutLabels(u);}
    const now=new Date();
